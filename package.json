{
  "name": "business-observability-engine",
  "version": "2.9.10",
  "private": true,
  "description": "Dynatrace Business Observability App with Smartscape-inspired UI and Node.js server",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node --require ./otel.cjs server.js",
    "dev": "NODE_ENV=development node --require ./otel.cjs server.js",
    "validate": "node scripts/validate-startup.cjs",
    "restart-services": "curl -X POST http://localhost:${PORT:-8080}/api/admin/services/restart-all",
    "build:agents": "npx tsc --project tsconfig.json",
    "prebuild": "npm run build:agents",
    "configure:dynatrace": "node dynatrace-monaco/deploy.cjs",
    "configure:monaco": "cd dynatrace-monaco && monaco deploy manifest.yaml",
    "app:build": "dt-app build",
    "app:start": "dt-app dev",
    "app:deploy": "dt-app deploy",
    "app:uninstall": "dt-app uninstall"
  },
  "dependencies": {
    "@dynatrace-sdk/app-environment": "^1.1.4",
    "@dynatrace-sdk/client-app-engine-edge-connect": "^1.6.9",
    "@dynatrace-sdk/client-classic-environment-v2": "^5.1.0",
    "@dynatrace-sdk/client-filter-segment-management": "^1.7.1",
    "@dynatrace-sdk/client-notification-v2": "^1.0.0",
    "@dynatrace-sdk/client-query": "^1.21.2",
    "@dynatrace-sdk/error-handlers": "^1.3.1",
    "@dynatrace-sdk/navigation": "^2.2.0",
    "@dynatrace-sdk/react-hooks": "^1.6.0",
    "@dynatrace-sdk/user-preferences": "^1.1.3",
    "@dynatrace/oneagent": "^1.325.69-1.0.0",
    "@dynatrace/strato-components": "^1.14.0",
    "@dynatrace/strato-components-preview": "^2.12.2",
    "@dynatrace/strato-design-tokens": "^1.2.0",
    "@dynatrace/strato-icons": "^1.11.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.212.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.212.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.212.0",
    "@opentelemetry/instrumentation-http": "^0.212.0",
    "@opentelemetry/resources": "^2.5.1",
    "@opentelemetry/sdk-logs": "^0.212.0",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/sdk-trace-node": "^2.5.1",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "morgan": "^1.10.0",
    "node-fetch": "^2.7.0",
    "open": "^8.4.2",
    "qs": "^6.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "6.6.2",
    "react-router-dom": "^6.22.2",
    "simple-oauth2": "^5.1.0",
    "socket.io": "^4.7.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "uuid": "^9.0.1"
  },
  "optionalDependencies": {
    "@dynatrace/oneagent-sdk": "^1.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "dt-app": "^1.6.2"
  }
}
